# Docker Compose environment variables.
# Copy this file to `.env` at the repo root:  cp .env.docker.example .env
# The `.env` file is gitignored — safe for local overrides.

# MySQL
MYSQL_ROOT_PASSWORD=dev-root-pwd
MYSQL_DATABASE=nimes_alerie
MYSQL_USER=app
MYSQL_PASSWORD=dev-app-pwd
MYSQL_PORT=3306

# Symfony
APP_ENV=dev
APP_SECRET=dev-only-change-in-production
JWT_PASSPHRASE=dev-only-change-in-production

# Mailer (null = no emails sent)
MAILER_DSN=null://null

# Frontend URL (used in confirmation emails)
FRONTEND_URL=http://localhost:4200
