###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=CHANGEZ_CETTE_VALEUR_AVEC_UN_SECRET_ALEATOIRE
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
# Format: mysql://user:password@host:port/database?serverVersion=8.0
DATABASE_URL="mysql://app:secret@127.0.0.1:3306/nimes_alerie?serverVersion=8.0"
# Avec Docker : DATABASE_URL="mysql://app:secret@database:3306/nimes_alerie?serverVersion=8.0"
###< doctrine/doctrine-bundle ###

###> lexik/jwt-authentication-bundle ###
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=CHANGEZ_CETTE_PASSPHRASE
###< lexik/jwt-authentication-bundle ###

###> nelmio/cors-bundle ###
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'
###< nelmio/cors-bundle ###

###> symfony/lock ###
LOCK_DSN=semaphore
###< symfony/lock ###

###> symfony/mailer ###
# Use "null://null" to swallow outgoing mails, or a real DSN in prod
# (e.g. smtp://user:pass@smtp.example.com:587)
MAILER_DSN=null://null
###< symfony/mailer ###

###> application ###
# Public URL of the Angular frontend, used to build verification / reset links
FRONTEND_URL=http://localhost:4200
###< application ###

###> paypal/sandbox ###
# Récupérer sur https://developer.paypal.com → Apps & Credentials → Sandbox
PAYPAL_CLIENT_ID=YOUR_SANDBOX_CLIENT_ID
PAYPAL_CLIENT_SECRET=YOUR_SANDBOX_CLIENT_SECRET
###< paypal/sandbox ###
