# This file is committed and provides default values for every env var
# the application needs. Override secrets and environment-specific values
# in `.env.local` (gitignored). See `.env.example` for the canonical
# template and documentation of each variable.

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=CHANGEZ_CETTE_VALEUR_AVEC_UN_SECRET_ALEATOIRE
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
DATABASE_URL="mysql://app:PLACEHOLDER_DB_PWD@127.0.0.1:3306/nimes_alerie?serverVersion=8.0"
###< doctrine/doctrine-bundle ###

###> lexik/jwt-authentication-bundle ###
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=CHANGEZ_CETTE_PASSPHRASE
###< lexik/jwt-authentication-bundle ###

###> nelmio/cors-bundle ###
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'
###< nelmio/cors-bundle ###

###> symfony/lock ###
LOCK_DSN=semaphore
###< symfony/lock ###

###> symfony/mailer ###
MAILER_DSN=null://null
###< symfony/mailer ###

###> application ###
FRONTEND_URL=http://localhost:4200
###< application ###
