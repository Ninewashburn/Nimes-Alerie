# define your env variables for the test env here
KERNEL_CLASS='App\Kernel'
APP_SECRET=ci-test-secret-not-a-real-value
SYMFONY_DEPRECATIONS_HELPER=999999
PANTHER_APP_ENV=panther
PANTHER_ERROR_SCREENSHOT_DIR=./var/error-screenshots

# Default values so `vendor/bin/phpunit` works without extra env setup.
# CI overrides these via the workflow job `env:` section.
DATABASE_URL="mysql://app:secret@127.0.0.1:3306/nimes_alerie?serverVersion=8.0"
MAILER_DSN=null://null
FRONTEND_URL=http://localhost:4200

JWT_SECRET_KEY='%kernel.project_dir%/config/jwt/private.pem'
JWT_PUBLIC_KEY='%kernel.project_dir%/config/jwt/public.pem'
JWT_PASSPHRASE=ci-test-passphrase

CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'
LOCK_DSN=semaphore
